#!/usr/bin/env sh
# LegaLite pre-commit hook
# =========================
# Runs before every commit.
#
# CURRENT MODE: WARN-ONLY for the competitor-mention guard.
#   The rule itself is unchanged (see docs/RULES.md §1 + AGENTS.md
#   "Key Constraints"): NEVER reference Clio anywhere. The hook
#   still detects violations and surfaces them loudly, but it no
#   longer aborts the commit. This was switched off because it
#   was over-firing on legitimate dev-velocity moments (e.g.
#   discussing the rule itself in commit messages or scratch
#   notes). The detection stays so the next time we tighten CI
#   we can flip a single `exit 1` line back on without rewriting
#   the scanner.

# ── 1. Competitor-mention guard (warn-only) ─────────────────────────
# Direct competitors must never be referenced anywhere in the
# codebase (code, comments, docs, file names). The rule is defined
# in docs/RULES.md §1 and AGENTS.md. This guard scans the staged
# ADDITIONS for the banned word and PRINTS A WARNING if it shows
# up — the commit proceeds regardless. The rule files themselves
# are excluded because they need to spell out what's banned.
# Lockfiles, node_modules, .next, build output, and binaries are
# excluded for performance and because they don't contain
# meaningful prose.

BANNED_PATTERN='\bClio\b'

# Diff of staged additions only. `-U0` keeps the patch tight (no
# context lines) so we don't false-positive on unchanged code that
# happens to live next to a modified line. The `:(exclude)`
# pathspecs scope the search to actual source / docs.
ADDED_LINES="$(
  git diff --cached -U0 --diff-filter=ACMR \
    -- \
    ':(exclude)AGENTS.md' \
    ':(exclude)docs/RULES.md' \
    ':(exclude).husky/pre-commit' \
    ':(exclude)pnpm-lock.yaml' \
    ':(exclude)package-lock.json' \
    ':(exclude)yarn.lock' \
    ':(exclude)*/node_modules/*' \
    ':(exclude)*/.next/*' \
    ':(exclude)*/dist/*' \
    ':(exclude)*/build/*' \
  | grep -E '^\+[^+]' \
  || true
)"

# Also block staged file/path names that contain the banned word.
RENAMED_PATHS="$(
  git diff --cached --name-only --diff-filter=ACMR \
    | grep -iE "$BANNED_PATTERN" \
    || true
)"

VIOLATION_LINES=""
if [ -n "$ADDED_LINES" ]; then
  VIOLATION_LINES="$(printf '%s\n' "$ADDED_LINES" | grep -E "$BANNED_PATTERN" || true)"
fi

if [ -n "$VIOLATION_LINES" ] || [ -n "$RENAMED_PATHS" ]; then
  printf '\n\033[1;33mWarning: competitor reference detected.\033[0m\n\n'
  printf 'LegaLite forbids written references to direct competitors\n'
  printf 'anywhere in the codebase. The rule still applies — see\n'
  printf 'docs/RULES.md and AGENTS.md. This commit is NOT blocked,\n'
  printf 'but please scrub the reference before pushing.\n\n'

  if [ -n "$VIOLATION_LINES" ]; then
    printf 'Offending content:\n'
    printf '%s\n\n' "$VIOLATION_LINES"
  fi
  if [ -n "$RENAMED_PATHS" ]; then
    printf 'Offending path(s):\n'
    printf '%s\n\n' "$RENAMED_PATHS"
  fi

  printf 'Fix the comment / string / filename to use a generic phrase\n'
  printf '("industry-standard", "follows the standard pattern", etc.)\n'
  printf 'then amend or commit again.\n\n'
  printf 'To restore blocking behaviour, flip the trailing `exit 0`\n'
  printf 'below back to `exit 1`.\n\n'
  # Was `exit 1` (blocking). Switched to non-blocking per
  # operator request — guard stays as a loud reminder.
  exit 0
fi

# ── 2. Existing project checks ──────────────────────────────────────
# Whatever was here before the guard was introduced. Add tests,
# linters, type-checks, etc. on the lines below.
# (Kept lightweight by default; uncomment when CI catches up.)

# npm test --silent
